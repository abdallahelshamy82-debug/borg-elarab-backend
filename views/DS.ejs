<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | Core System</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Rajdhani', sans-serif;
        }

        body {
            background-color: #0f1016;
            color: white;
            min-height: 100vh;
            overflow-x: hidden;
            opacity: 0;
            animation: fadeIn 0.5s ease-in forwards;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* --- الشريط العلوي --- */
        .navbar {
            background: rgba(21, 22, 30, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #2b2d3c;
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .logo span {
            color: #00ffaa;
        }

        .nav-links {
            display: flex;
            gap: 30px;
        }

        .nav-links a {
            color: #888;
            text-decoration: none;
            font-size: 18px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: color 0.3s;
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: #00ffaa;
        }

        /* --- Hamburger Menu --- */
        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            z-index: 101;
        }

        .hamburger span {
            width: 30px;
            height: 3px;
            background-color: #fff;
            border-radius: 3px;
            transition: all 0.3s ease;
        }

        @media (max-width: 900px) {
            .navbar {
                padding: 15px 20px;
            }

            .hamburger {
                display: flex;
            }

            .nav-links {
                position: fixed;
                top: 0;
                right: -100%;
                width: 250px;
                height: 100vh;
                background: #15161e;
                flex-direction: column;
                align-items: flex-start;
                padding: 80px 30px 30px;
                box-shadow: -10px 0 30px rgba(0, 0, 0, 0.5);
                transition: right 0.4s ease;
                z-index: 100;
                border-left: 1px solid #2b2d3c;
            }

            .nav-links.active {
                right: 0;
            }

            .hamburger.active span:nth-child(1) {
                transform: translateY(8px) rotate(45deg);
                background-color: #00ffaa;
            }

            .hamburger.active span:nth-child(2) {
                opacity: 0;
            }

            .hamburger.active span:nth-child(3) {
                transform: translateY(-8px) rotate(-45deg);
                background-color: #00ffaa;
            }
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: #00ffaa;
        }

        /* --- محتوى الصفحة --- */
        .container {
            padding: 40px 50px;
            max-width: 1300px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 40px;
        }

        /* --- الشريط الجانبي (البروفايل) --- */
        .profile-sidebar {
            background: #15161e;
            border: 1px solid #2b2d3c;
            border-radius: 16px;
            padding: 30px;
            text-align: center;
            height: fit-content;
        }

        .avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, #00ffaa, #0088ff);
            margin: 0 auto 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 40px;
            font-weight: 700;
            color: #0f1016;
            box-shadow: 0 0 20px rgba(0, 255, 170, 0.3);
        }

        .student-name {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .student-id {
            color: #888;
            font-size: 16px;
            margin-bottom: 30px;
            letter-spacing: 1px;
        }

        .balance-box {
            background: rgba(0, 255, 170, 0.05);
            border: 1px dashed #00ffaa;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 20px;
        }

        .balance-box h3 {
            font-size: 14px;
            color: #aaa;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .balance-box .points {
            font-size: 36px;
            font-weight: 700;
            color: #00ffaa;
            margin-top: 5px;
        }

        .action-btn {
            display: block;
            width: 100%;
            background: transparent;
            color: #fff;
            border: 1px solid #3a3c4f;
            padding: 12px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .action-btn:hover {
            border-color: #00ffaa;
            color: #00ffaa;
            background: rgba(0, 255, 170, 0.05);
        }

        /* --- القسم الرئيسي (المكتبة والسجل) --- */
        .main-content {
            display: flex;
            flex-direction: column;
            gap: 40px;
        }

        .section-header {
            font-size: 24px;
            font-weight: 700;
            border-bottom: 2px solid #2b2d3c;
            padding-bottom: 15px;
            margin-bottom: 25px;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* شبكة المكتبة */
        .library-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .lib-card {
            background: linear-gradient(180deg, #1a1c29, #15161e);
            border: 1px solid #2b2d3c;
            border-radius: 12px;
            padding: 20px;
            transition: transform 0.3s;
        }

        .lib-card:hover {
            transform: translateY(-5px);
            border-color: #00ffaa;
        }

        .lib-type {
            font-size: 12px;
            color: #00ffaa;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .lib-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 20px;
            line-height: 1.2;
        }

        .access-btn {
            background: #00ffaa;
            color: #0f1016;
            border: none;
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            transition: background 0.3s;
        }

        .access-btn:hover {
            background: #33ffbb;
        }

        /* جدول العمليات */
        .history-table {
            width: 100%;
            border-collapse: collapse;
            background: #15161e;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #2b2d3c;
        }

        .history-table th,
        .history-table td {
            padding: 15px 20px;
            text-align: left;
            border-bottom: 1px solid #2b2d3c;
        }

        .history-table th {
            background: #1a1c29;
            color: #888;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 14px;
        }

        .history-table tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .type-add {
            color: #00ffaa;
            font-weight: 700;
        }

        .type-sub {
            color: #ff4444;
            font-weight: 700;
        }

        /* --- النافذة المنبثقة (Modal) لمشاهدة المحتوى --- */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(15, 16, 22, 0.9);
            backdrop-filter: blur(5px);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .modal-box {
            background: #15161e;
            border: 1px solid #3a3c4f;
            border-radius: 16px;
            padding: 40px;
            width: 90%;
            max-width: 600px;
            text-align: center;
            transform: translateY(30px);
            transition: transform 0.3s ease;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
            position: relative;
        }

        .modal-overlay.active .modal-box {
            transform: translateY(0);
        }

        .close-modal {
            position: absolute;
            top: 15px;
            right: 20px;
            background: transparent;
            color: #888;
            border: none;
            font-size: 24px;
            cursor: pointer;
            transition: color 0.3s;
        }

        .close-modal:hover {
            color: #ff4444;
        }

        .viewer-icon {
            font-size: 60px;
            margin-bottom: 20px;
        }

        .modal-title {
            font-size: 24px;
            margin-bottom: 10px;
            color: #fff;
        }

        .modal-subtitle {
            color: #888;
            font-size: 16px;
            margin-bottom: 30px;
        }

        .simulate-bar {
            width: 100%;
            height: 6px;
            background: #2b2d3c;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 30px;
            display: none;
        }

        .simulate-progress {
            height: 100%;
            width: 0%;
            background: #00ffaa;
            border-radius: 10px;
            transition: width 2s ease-in-out;
        }

        @media (max-width: 900px) {
            .container {
                grid-template-columns: 1fr;
            }
        }

        /* --- Toast Notifications --- */
        #toast-container {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 1000;
        }

        .toast {
            background: #15161e;
            color: #fff;
            border-left: 4px solid #00ffaa;
            padding: 15px 25px;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-width: 300px;
            transform: translateX(120%);
            transition: transform 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            opacity: 0;
        }

        .toast.show {
            transform: translateX(0);
            opacity: 1;
        }

        .toast.error {
            border-left-color: #ff4444;
        }

        .toast.warning {
            border-left-color: #ffbb33;
        }

        .empty-state {
            text-align: center;
            padding: 40px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px dashed #3a3c4f;
            border-radius: 12px;
            color: #888;
            font-size: 18px;
            font-weight: 600;
        }

        .empty-state a {
            color: #00ffaa;
            text-decoration: none;
            margin-left: 10px;
        }

        .empty-state a:hover {
            text-decoration: underline;
        }

        /* --- Animations --- */
        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-card {
            opacity: 0;
            /* Hidden initially */
            animation: slideUp 0.5s ease-out forwards;
        }

        /* --- Edit Profile Modal --- */
        .profile-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(15, 16, 22, 0.9);
            backdrop-filter: blur(5px);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .profile-modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .profile-modal-box {
            background: #15161e;
            border: 1px solid #3a3c4f;
            border-radius: 16px;
            padding: 40px;
            width: 90%;
            max-width: 450px;
            text-align: center;
            transform: translateY(30px);
            transition: transform 0.3s ease;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
            position: relative;
        }

        .profile-modal-overlay.active .profile-modal-box {
            transform: translateY(0);
        }

        .input-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .input-group label {
            display: block;
            color: #aaa;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .input-group input {
            width: 100%;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid #3a3c4f;
            padding: 12px;
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
            transition: all 0.3s;
            outline: none;
        }

        .input-group input:focus {
            border-color: #00ffaa;
            background: rgba(0, 255, 170, 0.05);
            box-shadow: 0 0 15px rgba(0, 255, 170, 0.1);
        }
    </style>
</head>

