<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>University Store | Core System</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Rajdhani', sans-serif;
        }

        body {
            background-color: #0f1016;
            color: white;
            min-height: 100vh;
            overflow-x: hidden;
            opacity: 0;
            animation: fadeIn 0.5s ease-in forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* --- الشريط العلوي --- */
        .navbar {
            background: rgba(21, 22, 30, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #2b2d3c;
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .logo span {
            color: #00ffaa;
        }

        .balance-badge {
            background: rgba(0, 255, 170, 0.1);
            border: 1px solid #00ffaa;
            padding: 8px 20px;
            border-radius: 20px;
            font-size: 18px;
            font-weight: 700;
            color: #00ffaa;
            box-shadow: 0 0 15px rgba(0, 255, 170, 0.2);
            transition: all 0.3s;
        }

        /* --- Hamburger Menu --- */
        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            z-index: 101;
        }

        .hamburger span {
            width: 30px;
            height: 3px;
            background-color: #fff;
            border-radius: 3px;
            transition: all 0.3s ease;
        }

        @media (max-width: 900px) {
            .navbar {
                padding: 15px 20px;
                flex-wrap: wrap;
            }

            .logo {
                flex-grow: 1;
            }

            .balance-badge {
                order: 3;
                width: 100%;
                text-align: center;
                margin-top: 15px;
            }

            .hamburger {
                display: flex;
                order: 2;
                margin-left: auto;
            }

            .nav-links {
                position: fixed;
                top: 0;
                right: -100%;
                width: 250px;
                height: 100vh;
                background: #15161e;
                flex-direction: column;
                align-items: flex-start;
                padding: 80px 30px 30px;
                box-shadow: -10px 0 30px rgba(0,0,0,0.5);
                transition: right 0.4s ease;
                z-index: 100;
                border-left: 1px solid #2b2d3c;
                margin: 0 !important;
                gap: 20px !important;
            }

            .nav-links a {
                margin: 0 !important;
            }

            .nav-links.active {
                right: 0;
            }

            .hamburger.active span:nth-child(1) {
                transform: translateY(8px) rotate(45deg);
                background-color: #00ffaa;
            }

            .hamburger.active span:nth-child(2) {
                opacity: 0;
            }

            .hamburger.active span:nth-child(3) {
                transform: translateY(-8px) rotate(-45deg);
                background-color: #00ffaa;
            }
        }
        /* --- محتوى الصفحة --- */
        .container {
            padding: 50px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .page-title {
            font-size: 36px;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .page-subtitle {
            color: #888;
            margin-bottom: 40px;
            font-size: 18px;
        }

        /* --- Animations --- */
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-card {
            opacity: 0; /* Hidden initially */
            animation: slideUp 0.5s ease-out forwards;
        }

        /* --- شبكة الكروت --- */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .card {
            background: #15161e;
            border: 1px solid #2b2d3c;
            border-radius: 16px;
            padding: 25px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 4px;
            background: linear-gradient(90deg, #00ffaa, transparent);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.5), 0 0 20px rgba(0, 255, 170, 0.1);
            border-color: #3a3c4f;
        }

        .card:hover::before {
            opacity: 1;
        }

        .card-type {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #00ffaa;
            margin-bottom: 15px;
        }

        .card-title {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 15px;
            color: #fff;
            line-height: 1.2;
        }

        .card-price {
            font-size: 28px;
            font-weight: 700;
            color: #fff;
            margin-top: auto; /* يخلي السعر والزرار دايماً تحت */
            padding-top: 20px;
            border-top: 1px solid #2b2d3c;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-price span {
            color: #00ffaa;
            font-size: 20px;
        }

        .buy-btn {
            background: transparent;
            color: #00ffaa;
            border: 2px solid #00ffaa;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
        }

        .buy-btn:hover {
            background: #00ffaa;
            color: #0f1016;
            box-shadow: 0 0 15px rgba(0, 255, 170, 0.4);
        }

        /* --- النافذة المنبثقة (Modal) --- */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(15, 16, 22, 0.9);
            backdrop-filter: blur(5px);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .modal-box {
            background: #15161e;
            border: 1px solid #3a3c4f;
            border-radius: 16px;
            padding: 40px;
            width: 90%;
            max-width: 450px;
            text-align: center;
            transform: translateY(30px);
            transition: transform 0.3s ease;
            box-shadow: 0 20px 50px rgba(0,0,0,0.8);
        }

        .modal-overlay.active .modal-box {
            transform: translateY(0);
        }

        .modal-title {
            font-size: 24px;
            margin-bottom: 20px;
            color: #fff;
        }

        .modal-details {
            background: rgba(0, 0, 0, 0.3);
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
            font-size: 18px;
            color: #ccc;
        }

        .modal-details span {
            display: block;
            color: #00ffaa;
            font-size: 28px;
            font-weight: 700;
            margin-top: 10px;
        }

        .modal-actions {
            display: flex;
            gap: 15px;
        }

        .confirm-btn, .cancel-btn {
            flex: 1;
            padding: 12px;
            border-radius: 8px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
        }

        .confirm-btn {
            background: #00ffaa;
            color: #0f1016;
            border: none;
        }

        .confirm-btn:hover {
            background: #33ffbb;
            box-shadow: 0 0 15px rgba(0, 255, 170, 0.4);
        }

        .cancel-btn {
            background: transparent;
            color: #888;
            border: 1px solid #444;
        }

        .cancel-btn:hover {
            color: #fff;
            border-color: #888;
            background: rgba(255, 255, 255, 0.1);
        }

        /* --- Toast Notifications --- */
        #toast-container {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 1000;
        }

        .toast {
            background: #15161e;
            color: #fff;
            border-left: 4px solid #00ffaa;
            padding: 15px 25px;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-width: 300px;
            transform: translateX(120%);
            transition: transform 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            opacity: 0;
        }

        .toast.show {
            transform: translateX(0);
            opacity: 1;
        }

        .toast.error {
            border-left-color: #ff4444;
        }
        
    </style>
</head>
<body>

    <div id="toast-container"></div>

    <nav class="navbar">
        <div class="logo">Borg El Arab <span>Tech</span></div>
        <div class="hamburger" id="hamburgerMenu">
            <span></span>
            <span></span>
            <span></span>
        </div>
        <div class="nav-links" id="navLinks" style="display: flex; gap: 30px;">
            <a href="/" style="color: #888; text-decoration: none; font-size: 18px; font-weight: 600; text-transform: uppercase;">Dashboard</a>
            <a href="/" class="active" style="color: #00ffaa; text-decoration: none; font-size: 18px; font-weight: 600; text-transform: uppercase;">Store</a>
            <a href="/" style="color: #888; text-decoration: none; font-size: 18px; font-weight: 600; text-transform: uppercase;">Recharge</a>
            <form action="/" method="POST" style="display: flex; align-items: center; margin-left: auto;">
                
                <button type="submit" style="background: none; border: none; color: #888; font-size: 18px; font-weight: 600; text-transform: uppercase; cursor: pointer;">Logout</button>
            </form>
        </div>
        <div class="balance-badge" id="userBalanceDisplay">Balance: <%= user. %> Pt</div>
    </nav>

    <div class="container">
        <h1 class="page-title">Resource Store</h1>
        <p class="page-subtitle">Exchange your core points for university materials.</p>

        <div class="grid">
            <% if() { %>)
                <div class="toast success show" style="margin-bottom: 20px; position: relative; bottom: auto; right: auto; transform: none; min-width: auto; grid-column: 1 / -1;">
                    <span><%=  %></span>
                </div>
            <% } %>
            <% if() { %>)
                <div class="toast error show" style="margin-bottom: 20px; position: relative; bottom: auto; right: auto; transform: none; min-width: auto; grid-column: 1 / -1;">
                    <span><%=  %></span>
                </div>
            <% } %>

            <% .forEach( => { %>
            @php
                $isPurchased = Auth::user()->purchases()->where('item_id', $item->id)->exists();
            @endphp
            <div class="card animate-card" style="animation-delay: <%=  %>s">
                <img src="<%=  %>" alt="<%=  %>" style="width: 100%; height: 180px; object-fit: cover; border-radius: 12px; margin-bottom: 20px; border: 1px solid #2b2d3c;">
                <div class="card-type"><%=  %></div>
                <h2 class="card-title"><%=  %></h2>
                <div class="card-price">
                    <%=  %> <span>Pt</span>
                    <% if() { %>
                        <button class="buy-btn" style="border-color: #3a3c4f; color: #888; cursor: not-allowed; background: transparent;" disabled>Purchased</button>
                    <% } else { %>
                        <form action="//" method="POST" style="margin: 0;">
                            
                            <button type="submit" class="buy-btn">Book</button>
                        </form>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
    </div>

    <div class="modal-overlay" id="purchaseModal">
        <div class="modal-box">
            <h3 class="modal-title">Confirm Purchase</h3>
            <div class="modal-details">
                You are about to unlock:
                <strong id="modalItemName" style="display: block; color: #fff; margin-top: 5px;">Item Name</strong>
                <span id="modalItemPrice">0 Pt</span>
            </div>
            <div class="modal-actions">
                <button class="cancel-btn" onclick="closeModal()">Cancel</button>
                <button class="confirm-btn" id="confirmPurchaseBtn">Confirm</button>
            </div>
        </div>
    </div>

    <script>
        // --- Toast System ---
        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `<span>${message}</span>`;
            
            container.appendChild(toast);
            
            // Trigger animation
            setTimeout(() => toast.classList.add('show'), 10);
            
            // Remove after 3s
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Hamburger Menu Toggle
        const hamburger = document.getElementById('hamburgerMenu');
        const navLinks = document.getElementById('navLinks');

        hamburger.addEventListener('click', () => {
            hamburger.classList.toggle('active');
            navLinks.classList.toggle('active');
        });

        // Close menu when clicking outside
        document.addEventListener('click', (e) => {
            if (!hamburger.contains(e.target) && !navLinks.contains(e.target) && navLinks.classList.contains('active')) {
                hamburger.classList.remove('active');
                navLinks.classList.remove('active');
            }
        });
    </script>
</body>
</html>