<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user.isAdmin() ? 'Admin' : 'Doctor' %> Dashboard | Core System</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Rajdhani', sans-serif;
        }

        body {
            background-color: #0f1016;
            color: white;
            min-height: 100vh;
            overflow-x: hidden;
            opacity: 0;
            animation: fadeIn 0.5s ease-in forwards;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .navbar {
            background: rgba(21, 22, 30, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #2b2d3c;
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .logo span {
            color: #ff0055; /* Admin accent color */
        }

        .nav-links {
            display: flex;
            gap: 30px;
        }

        .nav-links a, .nav-links button {
            color: #888;
            text-decoration: none;
            font-size: 18px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: color 0.3s;
            background: none;
            border: none;
            cursor: pointer;
        }

        .nav-links a:hover,
        .nav-links button:hover,
        .nav-links a.active {
            color: #ff0055;
        }

        .container {
            padding: 40px 50px;
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 40px;
        }

        .admin-sidebar {
            background: #15161e;
            border: 1px solid #2b2d3c;
            border-radius: 16px;
            padding: 30px;
            height: fit-content;
        }

        .admin-sidebar h2 {
            font-size: 24px;
            margin-bottom: 20px;
            border-bottom: 2px solid #2b2d3c;
            padding-bottom: 10px;
            color: #ff0055;
            text-transform: uppercase;
        }

        .input-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .input-group label {
            display: block;
            color: #aaa;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .input-group input {
            width: 100%;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid #3a3c4f;
            padding: 12px;
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
            transition: all 0.3s;
            outline: none;
        }

        .input-group input:focus {
            border-color: #ff0055;
            background: rgba(255, 0, 85, 0.05);
            box-shadow: 0 0 15px rgba(255, 0, 85, 0.1);
        }

        .action-btn {
            display: block;
            width: 100%;
            background: rgba(255, 0, 85, 0.1);
            color: #ff0055;
            border: 1px solid #ff0055;
            padding: 12px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
        }

        .action-btn:hover {
            background: #ff0055;
            color: #fff;
        }

        .main-content {
            display: flex;
            flex-direction: column;
            gap: 40px;
        }

        .section-header {
            font-size: 24px;
            font-weight: 700;
            border-bottom: 2px solid #2b2d3c;
            padding-bottom: 15px;
            margin-bottom: 25px;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .history-table {
            width: 100%;
            border-collapse: collapse;
            background: #15161e;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #2b2d3c;
        }

        .history-table th,
        .history-table td {
            padding: 15px 20px;
            text-align: left;
            border-bottom: 1px solid #2b2d3c;
        }

        .history-table th {
            background: #1a1c29;
            color: #888;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 14px;
        }

        .history-table tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .status-active {
            color: #00ffaa;
            font-weight: 700;
        }

        .status-suspended {
            color: #ff4444;
            font-weight: 700;
        }

        .btn-small {
            background: transparent;
            color: #fff;
            border: 1px solid #3a3c4f;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-small:hover {
            border-color: #ff0055;
            color: #ff0055;
        }

        /* --- Toast Notifications --- */
        #toast-container {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 1000;
        }

        .toast {
            background: #15161e;
            color: #fff;
            border-left: 4px solid #00ffaa;
            padding: 15px 25px;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-width: 300px;
            animation: slideIn 0.3s forwards;
        }

        .toast.error {
            border-left-color: #ff4444;
        }

        /* --- Tabs --- */
        .tabs {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
            border-bottom: 2px solid #2b2d3c;
            padding-bottom: 10px;
        }

        .tab-btn {
            background: none;
            border: none;
            color: #888;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            padding: 10px 20px;
            text-transform: uppercase;
            transition: color 0.3s;
            position: relative;
        }

        .tab-btn:hover, .tab-btn.active {
            color: #00ffaa;
        }

        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -12px;
            left: 0;
            width: 100%;
            height: 3px;
            background: #00ffaa;
            border-radius: 3px;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 40px;
        }

        @media (max-width: 900px) {
            .tab-content.active {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

    <nav class="navbar">
        <div class="logo"><%= user.isAdmin() ? 'System' : 'Course' %> <span>Management</span></div>
        <div class="nav-links">
            <a href="/store.ds" class="active">View Profile</a>
            <form action="/logout" method="POST" style="display: inline;">
                
                <button type="submit">Logout</button>
            </form>
        </div>
    </nav>

    <div class="container" style="display: block;">
        
        <div class="tabs">
            <% if(Auth::user() { %>->isAdmin())
            <button class="tab-btn active" onclick="switchTab('users')">User Management</button>
            <% } %>
            <button class="tab-btn <%= !Auth::user()->isAdmin() ? 'active' : '' %>" onclick="switchTab('courses')">Course Management</button>
        </div>

        <% if(success { %>)
            <div class="toast show" style="margin-bottom: 20px; position: relative; bottom: auto; right: auto; transform: none; min-width: auto; width: 100%;">
                <span><%= success %></span>
            </div>
        <% } %>
        <% if(error { %>)
            <div class="toast error show" style="margin-bottom: 20px; position: relative; bottom: auto; right: auto; transform: none; min-width: auto; width: 100%;">
                <span><%= error %></span>
            </div>
        <% } %>

        <% if(Auth::user() { %>->isAdmin())
        <!-- USERS TAB -->
        <div id="users-tab" class="tab-content active">
            <!-- Registration Form Sidebar -->
            <!-- Removed Add New User Sidebar -->

            <!-- Main Content -->
            <main class="main-content">
                <section>
                    <h2 class="section-header">Search User / Reset Password</h2>
                    <form action="/admin.searchUser" method="GET" style="display: flex; gap: 15px; margin-bottom: 30px;">
                        <input type="text" name="user_id" required placeholder="Enter User ID (Email)..." style="flex: 1; background: rgba(255, 255, 255, 0.02); border: 1px solid #3a3c4f; padding: 12px; border-radius: 8px; color: #fff; font-size: 16px; outline: none;">
                        <button type="submit" class="action-btn" style="width: auto; padding: 0 30px;">Search User</button>
                    </form>
                </section>

                <!-- Removed System Users Table -->
            </main>
        </div>
        <% } %>

        <!-- COURSES TAB -->
        <div id="courses-tab" class="tab-content <%= !Auth::user()->isAdmin() ? 'active' : '' %>">
            <!-- Course Upload Sidebar -->
            <aside class="admin-sidebar" style="height: fit-content; border-color: #00ffaa;">
                <h2 style="color: #00ffaa; border-color: #2b2d3c;">Upload Course Material</h2>
                <form action="/admin.storeCourse" method="POST" enctype="multipart/form-data">
                    
                    <div class="input-group">
                        <label for="c_name">Title</label>
                        <input type="text" id="c_name" name="name" required placeholder="e.g. Physics 101 Notes">
                    </div>
                    <div class="input-group">
                        <label for="c_desc">Description</label>
                        <input type="text" id="c_desc" name="description" required placeholder="Brief description...">
                    </div>
                    <div class="input-group">
                        <label for="category">Category</label>
                        <select id="category" name="category" required style="width: 100%; background: rgba(255, 255, 255, 0.02); border: 1px solid #3a3c4f; padding: 12px; border-radius: 8px; color: #fff; font-size: 16px; outline: none;">
                            <option value="Notes" style="color: black;">Notes (PDF)</option>
                            <option value="Video Lectures" style="color: black;">Video Lectures (MP4)</option>
                            <option value="Exams" style="color: black;">Previous Exams</option>
                            <option value="Projects" style="color: black;">Project Files</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label for="price">Price (Pt)</label>
                        <input type="number" id="price" name="price" required min="0" placeholder="e.g. 150">
                    </div>

                    <div class="input-group">
                        <label for="image_url">Cover Image (required)</label>
                        <input type="file" id="image_url" name="image_url" accept="image/*" required style="padding: 10px;">
                    </div>
                    
                    <div class="input-group">
                        <label for="file_path">Course Material</label>
                        <input type="file" id="file_path" name="file_path" accept=".pdf,.doc,.docx,.mp4,.zip" style="padding: 10px;">
                        <small style="color:#888;">Leave empty if physical item</small>
                    </div>

                    <button type="submit" class="action-btn" style="color:#00ffaa; border-color:#00ffaa; background: rgba(0, 255, 170, 0.1);">Upload Material</button>
                </form>
            </aside>

            <!-- Main Content -->
            <main class="main-content">
                <section>
                    <h2 class="section-header">Uploaded Materials</h2>
                    <table class="history-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Type</th>
                                <th>Price</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @forelse($courses as $course)
                            <tr>
                                <td style="font-weight: bold;"><%= $course->name %></td>
                                <td style="color: #888;"><%= $course->category %></td>
                                <td><%= $course->price %> Pt</td>
                                <td>
                                    <!-- Add delete function later if needed -->
                                    <span class="status-active">Available</span>
                                </td>
                            </tr>
                            @empty
                            <tr>
                                <td colspan="4" style="text-align: center; color: #888;">No materials uploaded yet.</td>
                            </tr>
                            @endforelse
                        </tbody>
                    </table>
                </section>
            </main>
        </div>

    </div>

    <script>
        function switchTab(tabId) {
            // Hide all tab contents
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            // Remove active class from buttons
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));

            // Show selected tab content
            document.getElementById(tabId + '-tab').classList.add('active');
            // Re-add active class to clicked button
            event.target.classList.add('active');
        }
    </script>
</body>
</html>
