<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Details | <%= $user->name %></title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Rajdhani', sans-serif;
        }

        body {
            background-color: #0f1016;
            color: white;
            min-height: 100vh;
            overflow-x: hidden;
            opacity: 0;
            animation: fadeIn 0.5s ease-in forwards;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .navbar {
            background: rgba(21, 22, 30, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #2b2d3c;
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .logo span {
            color: #ff0055;
        }

        .nav-links {
            display: flex;
            gap: 30px;
        }

        .nav-links a {
            color: #888;
            text-decoration: none;
            font-size: 18px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: color 0.3s;
        }

        .nav-links a:hover, .nav-links a.active {
            color: #ff0055;
        }

        .container {
            padding: 40px 50px;
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 40px;
        }

        .admin-sidebar {
            background: #15161e;
            border: 1px solid #2b2d3c;
            border-radius: 16px;
            padding: 30px;
            height: fit-content;
        }

        .admin-sidebar h2 {
            font-size: 24px;
            margin-bottom: 20px;
            border-bottom: 2px solid #2b2d3c;
            padding-bottom: 10px;
            color: #ff0055;
            text-transform: uppercase;
        }

        .info-group {
            margin-bottom: 15px;
        }

        .info-group label {
            display: block;
            color: #aaa;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }
        
        .info-group .value {
            color: #fff;
            font-size: 18px;
            font-weight: 600;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid #3a3c4f;
            padding: 10px;
            border-radius: 8px;
            word-break: break-all;
        }

        .status-active { color: #00ffaa; }
        .status-suspended { color: #ff4444; }

        .input-group {
            margin-bottom: 20px;
        }

        .input-group input {
            width: 100%;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid #3a3c4f;
            padding: 12px;
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
            outline: none;
            transition: all 0.3s;
        }

        .input-group input:focus {
            border-color: #ff0055;
        }

        .action-btn {
            display: block;
            width: 100%;
            background: rgba(255, 0, 85, 0.1);
            color: #ff0055;
            border: 1px solid #ff0055;
            padding: 12px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            text-align: center;
            text-decoration: none;
        }

        .action-btn:hover {
            background: #ff0055;
            color: #fff;
        }

        .main-content {
            display: flex;
            flex-direction: column;
            gap: 40px;
        }

        .section-header {
            font-size: 24px;
            font-weight: 700;
            border-bottom: 2px solid #2b2d3c;
            padding-bottom: 15px;
            margin-bottom: 25px;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .history-table {
            width: 100%;
            border-collapse: collapse;
            background: #15161e;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #2b2d3c;
        }

        .history-table th,
        .history-table td {
            padding: 15px 20px;
            text-align: left;
            border-bottom: 1px solid #2b2d3c;
        }

        .history-table th {
            background: #1a1c29;
            color: #888;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 14px;
        }

        .history-table tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        /* Toast Notifications */
        .toast {
            background: #15161e;
            color: #fff;
            border-left: 4px solid #00ffaa;
            padding: 15px 25px;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            font-size: 16px;
            margin-bottom: 20px;
        }
        .toast.error { border-left-color: #ff4444; }

        @media (max-width: 900px) {
            .container {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

    <nav class="navbar">
        <div class="logo">User <span>Lookup</span></div>
        <div class="nav-links">
            <a href="/admin.dashboard">Back to Dashboard</a>
        </div>
    </nav>

    <div class="container" style="display: block; max-width: 1400px; margin: 0 auto; padding-top: 20px;">
        <% if(success { %>)
            <div class="toast show"><%= success %></div>
        <% } %>
        <% if(error { %>)
            <div class="toast error show"><%= error %></div>
        <% } %>
        <% if($errors->any() { %>)
            <div class="toast error show">
                <ul style="list-style: none; margin: 0; padding: 0;">
                    @foreach ($errors->all() as $error)
                        <li><%= $error %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>
    </div>

    <div class="container">
        
        <!-- Sidebar - User Info & Password Reset -->
        <aside class="admin-sidebar">
            <h2>User Details</h2>
            
            <div class="info-group">
                <label>Name</label>
                <div class="value"><%= $user->name %></div>
            </div>
            
            <div class="info-group">
                <label>User ID / Email</label>
                <div class="value"><%= $user->email %></div>
            </div>

            <div class="info-group">
                <label>Role</label>
                <div class="value" style="text-transform: capitalize;"><%= $user->role %></div>
            </div>

            <div class="info-group">
                <label>Balance</label>
                <div class="value" style="color: #00ffaa;"><%= $user->balance %> Pt</div>
            </div>

            <div class="info-group">
                <label>Status</label>
                <div class="value <%= $user->is_active ? 'status-active' : 'status-suspended' %>">
                    <%= $user->is_active ? 'Active' : 'Suspended' %>
                </div>
            </div>

            <!-- Password Reset Section -->
            <h2 style="margin-top: 40px; border-color: #ffaa00; color: #ffaa00;">Reset Password</h2>
            <form action="/admin.resetUserPassword/$user->id" method="POST">
                
                <div class="input-group">
                    <input type="text" name="new_password" required placeholder="Enter New Password..." style="border-color: #555;">
                </div>
                <button type="submit" class="action-btn" onclick="return confirm('Are you sure you want to reset the password for <%= $user->name %>?');" style="color: #ffaa00; border-color: #ffaa00; background: rgba(255, 170, 0, 0.1);">Force Reset</button>
            </form>

            <!-- Update Balance Section -->
            <h2 style="margin-top: 40px; border-color: #00ffaa; color: #00ffaa;">Update Balance</h2>
            <form action="/admin.updateUserBalance/$user->id" method="POST">
                
                <div class="input-group">
                    <input type="number" name="points" required placeholder="Amount (e.g. 500, -200)..." style="border-color: #555;">
                </div>
                <div class="input-group" style="display: flex; gap: 10px;">
                    <label style="color: #aaa; font-size: 14px; text-transform: uppercase; display: flex; align-items: center; gap: 5px;">
                        <input type="radio" name="action" value="add" checked style="width: auto;"> Add/Subtract
                    </label>
                    <label style="color: #aaa; font-size: 14px; text-transform: uppercase; display: flex; align-items: center; gap: 5px;">
                        <input type="radio" name="action" value="set" style="width: auto;"> Set Exact
                    </label>
                </div>
                <button type="submit" class="action-btn" onclick="return confirm('Are you sure you want to update the balance?');" style="color: #00ffaa; border-color: #00ffaa; background: rgba(0, 255, 170, 0.1);">Update Points</button>
            </form>
        </aside>

        <!-- Main Content - Purchases & Recharges -->
        <main class="main-content">
            
            <section>
                <h2 class="section-header">Purchased Items</h2>
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>Item Name</th>
                            <th>Category</th>
                            <th>Cost</th>
                            <th>Purchase Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @forelse($user->purchases as $purchase)
                        <tr>
                            <td style="font-weight: bold;"><%= $purchase->item->name ?? 'Deleted Item' %></td>
                            <td style="color: #888;"><%= $purchase->item->category ?? 'N/A' %></td>
                            <td><%= $purchase->item->price ?? 0 %> Pt</td>
                            <td style="color: #888;"><%= $purchase->created_at->format('M d, Y h:i A') %></td>
                        </tr>
                        @empty
                        <tr>
                            <td colspan="4" style="text-align: center; color: #888;">No purchases found for this user.</td>
                        </tr>
                        @endforelse
                    </tbody>
                </table>
            </section>

            <section>
                <h2 class="section-header">Recharge History</h2>
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @forelse($user->recharges as $recharge)
                        <tr>
                            <td style="font-weight: bold; color: #00ffaa;">+<%= $recharge->amount %> Pt</td>
                            <td style="text-transform: capitalize;"><%= $recharge->method %></td>
                            <td>
                                <% if($recharge->status == 'completed') { %>
                                    <span style="color: #00ffaa;">Completed</span>
                                <% } else if($recharge->status == 'pending') { %>
                                    <span style="color: #ffaa00;">Pending</span>
                                <% } else { %>
                                    <span style="color: #ff4444;">Failed</span>
                                <% } %>
                            </td>
                            <td style="color: #888;"><%= $recharge->created_at->format('M d, Y h:i A') %></td>
                        </tr>
                        @empty
                        <tr>
                            <td colspan="4" style="text-align: center; color: #888;">No recharge history found.</td>
                        </tr>
                        @endforelse
                    </tbody>
                </table>
            </section>

        </main>
    </div>

</body>
</html>
