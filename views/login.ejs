<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Core System Login | Borg El Arab Tech</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Rajdhani', sans-serif;
        }

        body {
            background-color: #0f1016;
            color: white;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(0, 255, 170, 0.05), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(0, 136, 255, 0.05), transparent 25%);
            opacity: 0;
            animation: fadeIn 0.5s ease-in forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-box {
            background: #15161e;
            border: 1px solid #2b2d3c;
            border-radius: 16px;
            padding: 50px 40px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            position: relative;
            text-align: center;
        }

        .login-box::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 4px;
            background: linear-gradient(90deg, #0088ff, #00ffaa);
            border-radius: 16px 16px 0 0;
        }

        .logo {
            font-size: 32px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .logo span {
            color: #00ffaa;
        }

        .subtitle {
            color: #888;
            font-size: 16px;
            margin-bottom: 40px;
            letter-spacing: 1px;
        }

        .input-group {
            margin-bottom: 25px;
            text-align: left;
        }

        .input-group label {
            display: block;
            color: #aaa;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .input-group input {
            width: 100%;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid #3a3c4f;
            padding: 15px;
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
            transition: all 0.3s;
            outline: none;
        }

        .input-group input:focus {
            border-color: #00ffaa;
            background: rgba(0, 255, 170, 0.05);
            box-shadow: 0 0 15px rgba(0, 255, 170, 0.1);
        }

        .login-btn {
            width: 100%;
            background: #00ffaa;
            color: #0f1016;
            border: none;
            padding: 15px;
            border-radius: 8px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
            margin-top: 10px;
        }

        .login-btn:hover {
            background: #33ffbb;
            box-shadow: 0 0 20px rgba(0, 255, 170, 0.4);
            transform: translateY(-2px);
        }

        /* --- Toast Notifications --- */
        #toast-container {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 1000;
        }

        .toast {
            background: #15161e;
            color: #fff;
            border-left: 4px solid #00ffaa;
            padding: 15px 25px;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-width: 300px;
            transform: translateX(120%);
            transition: transform 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            opacity: 0;
        }

        .toast.show {
            transform: translateX(0);
            opacity: 1;
        }
        
        .toast.error {
            border-left-color: #ff4444;
        }

    </style>
</head>
<body>

    <div id="toast-container"></div>

    <div class="login-box">
        <% if (error) { %>
            <div class="toast error show" style="margin-bottom: 20px; position: relative; bottom: auto; right: auto; transform: none; min-width: auto; width: 100%;">
                <span><%= error %></span>
            </div>
        <% } %>

        <form id="loginForm" method="POST" action="/login">
            
            
            <div class="input-group">
                <label for="studentEmail">Student ID</label>
                <input type="text" id="studentEmail" name="email" value="" placeholder="e.g. 2420677" required autocomplete="username">
            </div>
            
            <div class="input-group">
                <label for="password">National ID / Password</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password">
            </div>

            <button type="submit" class="login-btn">Initialize Session</button>
        </form>
    </div>
</body>
</html>
