<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Core Energy Recharge</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Rajdhani', sans-serif;
        }

        body {
            background-color: #0f1016;
            color: white;
            min-height: 100vh;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
            opacity: 0;
            animation: fadeIn 0.5s ease-in forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* --- الشريط العلوي --- */
        .navbar {
            background: rgba(21, 22, 30, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #2b2d3c;
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .logo span {
            color: #00ffaa;
        }

        .nav-links {
            display: flex;
            gap: 30px;
        }

        .nav-links a {
            color: #888;
            text-decoration: none;
            font-size: 18px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: color 0.3s;
        }

        .nav-links a:hover, .nav-links a.active {
            color: #00ffaa;
        }

        /* --- Hamburger Menu --- */
        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            z-index: 101;
        }

        .hamburger span {
            width: 30px;
            height: 3px;
            background-color: #fff;
            border-radius: 3px;
            transition: all 0.3s ease;
        }

        @media (max-width: 900px) {
            .navbar {
                padding: 15px 20px;
            }

            .hamburger {
                display: flex;
            }

            .nav-links {
                position: fixed;
                top: 0;
                right: -100%;
                width: 250px;
                height: 100vh;
                background: #15161e;
                flex-direction: column;
                align-items: flex-start;
                padding: 80px 30px 30px;
                box-shadow: -10px 0 30px rgba(0,0,0,0.5);
                transition: right 0.4s ease;
                z-index: 100;
                border-left: 1px solid #2b2d3c;
            }

            .nav-links.active {
                right: 0;
            }

            .hamburger.active span:nth-child(1) {
                transform: translateY(8px) rotate(45deg);
                background-color: #00ffaa;
            }

            .hamburger.active span:nth-child(2) {
                opacity: 0;
            }

            .hamburger.active span:nth-child(3) {
                transform: translateY(-8px) rotate(-45deg);
                background-color: #00ffaa;
            }
        }

        .nav-links a:hover, .nav-links a.active {
            color: #00ffaa;
        }

        /* --- محتوى الصفحة --- */
        .main-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
        }

        .recharge-box {
            background: #15161e;
            border: 1px solid #2b2d3c;
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            position: relative;
        }

        .recharge-box::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 4px;
            background: linear-gradient(90deg, #00ffaa, transparent);
            border-radius: 16px 16px 0 0;
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 32px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .header p {
            color: #888;
            font-size: 16px;
            letter-spacing: 0.5px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-box {
            background: rgba(0, 255, 170, 0.05);
            border: 1px dashed #3a3c4f;
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            transition: all 0.3s;
        }

        .stat-box:hover {
            border-color: #00ffaa;
            background: rgba(0, 255, 170, 0.1);
        }

        .stat-label {
            display: block;
            color: #aaa;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .stat-value {
            font-size: 36px;
            font-weight: 700;
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 5px;
        }

        .points-text { color: #00ffaa; }
        .price-text { color: #fff; }

        .stat-unit {
            font-size: 16px;
            font-weight: 600;
            color: #888;
        }

        .slider-wrapper {
            margin-bottom: 40px;
        }

        /* Custom Slider */
        input[type=range] {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            background: transparent;
            height: 30px;
            outline: none;
        }

        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            height: 24px;
            width: 24px;
            border-radius: 50%;
            background: #00ffaa;
            cursor: pointer;
            margin-top: -10px;
            box-shadow: 0 0 15px rgba(0, 255, 170, 0.5);
            transition: transform 0.2s;
        }

        input[type=range]::-webkit-slider-thumb:hover {
            transform: scale(1.2);
        }

        input[type=range]::-webkit-slider-runnable-track {
            width: 100%;
            height: 4px;
            cursor: pointer;
            background: #2b2d3c;
            border-radius: 5px;
        }

        .slider-labels {
            display: flex;
            justify-content: space-between;
            color: #888;
            font-size: 14px;
            margin-top: 15px;
            font-weight: 600;
        }

        .pay-btn {
            width: 100%;
            background: #00ffaa;
            color: #0f1016;
            border: none;
            padding: 15px;
            border-radius: 8px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .pay-btn:hover {
            background: #33ffbb;
            box-shadow: 0 0 20px rgba(0, 255, 170, 0.4);
            transform: translateY(-2px);
        }

        .pay-btn.loading {
            pointer-events: none;
            opacity: 0.8;
            background: #888;
            box-shadow: none;
        }

        /* Spinner animation */
        @keyframes spin { 100% { transform: rotate(360deg); } }
        
        .spinner {
            display: none;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(15, 16, 22, 0.3);
            border-top-color: #0f1016;
            border-radius: 50%;
            animation: spin 0.8s infinite linear;
        }

        .pay-btn.loading .spinner { display: block; }

        @media (max-width: 600px) {
            .navbar { padding: 15px 20px; flex-direction: column; gap: 15px; }
            .recharge-box { padding: 30px 20px; }
        }

        /* --- Toast Notifications --- */
        #toast-container {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 1000;
        }

        .toast {
            background: #15161e;
            color: #fff;
            border-left: 4px solid #00ffaa;
            padding: 15px 25px;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-width: 300px;
            transform: translateX(120%);
            transition: transform 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            opacity: 0;
        }

        .toast.show {
            transform: translateX(0);
            opacity: 1;
        }

        .toast.error {
            border-left-color: #ff4444;
        }

    </style>
</head>
<body>

    <div id="toast-container"></div>

    <nav class="navbar">
        <div class="logo">Borg El Arab <span>Tech</span></div>
        <div class="hamburger" id="hamburgerMenu">
            <span></span>
            <span></span>
            <span></span>
        </div>
        <div class="nav-links" id="navLinks">
            <a href="/">Dashboard</a>
            <a href="/">Store</a>
            <a href="/" class="active">Recharge</a>
            <form action="/" method="POST" style="display: inline;">
                
                <button type="submit" style="background: none; border: none; color: #888; font-size: 18px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; padding: 0;">Logout</button>
            </form>
        </div>
    </nav>

    <div class="main-container">
        <div class="recharge-box">
             <% if() { %>)
                <div class="toast success show" style="margin-bottom: 20px; position: relative; bottom: auto; right: auto; transform: none; min-width: auto; width: 100%;">
                    <span><%=  %></span>
                </div>
            <% } %>
            <% if() { %>)
                <div class="toast error show" style="margin-bottom: 20px; position: relative; bottom: auto; right: auto; transform: none; min-width: auto; width: 100%;">
                    <span><%=  %></span>
                </div>
            <% } %>

            <div class="header">
                <h1>Core Energy</h1>
                <p>Select the amount of system points required</p>
            </div>

            <!-- Paymob Checkout Form -->
            <form action="/" method="POST" id="rechargeForm">
                
                <div class="stats-grid">
                    <div class="stat-box">
                        <span class="stat-label">Points Added</span>
                        <div class="stat-value points-text">
                            <span id="pointsOutput">40</span><span class="stat-unit">Pt</span>
                        </div>
                    </div>
                    <div class="stat-box">
                        <span class="stat-label">Total Cost</span>
                        <div class="stat-value price-text">
                            <span id="priceOutput">20</span><span class="stat-unit">EGP</span>
                        </div>
                    </div>
                </div>

                <div class="slider-wrapper">
                    <input type="range" name="amount" id="pointSlider" min="20" max="1000" step="20" value="40">
                    <div class="slider-labels">
                        <span>20 Pt</span>
                        <span>1000 Pt</span>
                    </div>
                </div>

                <button type="submit" class="pay-btn" id="payButton">
                    <span class="btn-text" id="btnText">Initiate Transfer</span>
                    <div class="spinner" id="btnSpinner"></div>
                </button>
            </form>
        </div>
    </div>

    <script>
        // --- Toast System ---
        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `<span>${message}</span>`;
            
            container.appendChild(toast);
            
            // Trigger animation
            setTimeout(() => toast.classList.add('show'), 10);
            
            // Remove after 3s
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function logoutUser() {
            // Logout is handled by the form in the navbar
        }

        // Hamburger Menu Toggle
        const hamburger = document.getElementById('hamburgerMenu');
        const navLinks = document.getElementById('navLinks');

        hamburger.addEventListener('click', () => {
            hamburger.classList.toggle('active');
            navLinks.classList.toggle('active');
        });

        // Close menu when clicking outside
        document.addEventListener('click', (e) => {
            if (!hamburger.contains(e.target) && !navLinks.contains(e.target) && navLinks.classList.contains('active')) {
                hamburger.classList.remove('active');
                navLinks.classList.remove('active');
            }
        });

        const pricePerPoint = 0.5;
        
        const pointSlider = document.getElementById('pointSlider');
        const pointsOutput = document.getElementById('pointsOutput');
        const priceOutput = document.getElementById('priceOutput');
        const payButton = document.getElementById('payButton');
        const btnText = document.getElementById('btnText');
        const btnSpinner = document.getElementById('btnSpinner');

        // Update slider track background dynamically
        function updateSliderTrack() {
            const min = parseFloat(pointSlider.min);
            const max = parseFloat(pointSlider.max);
            const val = parseFloat(pointSlider.value);
            const percentage = ((val - min) / (max - min)) * 100;
            pointSlider.style.background = `linear-gradient(to right, #00ffaa 0%, #00ffaa ${percentage}%, #2b2d3c ${percentage}%, #2b2d3c 100%)`;
        }

        pointSlider.addEventListener('input', function() {
            const points = parseInt(this.value);
            const price = points * pricePerPoint;

            pointsOutput.innerText = points;
            priceOutput.innerText = Number.isInteger(price) ? price : price.toFixed(1);

            updateSliderTrack();
        });

        // Initialize slider track on load
        updateSliderTrack();

        payButton.addEventListener('click', function() {
            payButton.classList.add('loading');
            btnText.innerText = "Processing...";
        });
    </script>
</body>
</html>