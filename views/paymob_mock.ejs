<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paymob Secure Checkout</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f7f9fc; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .checkout-box { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); text-align: center; max-width: 400px; width: 100%; border-top: 5px solid #0052cc; }
        h2 { color: #333; margin-bottom: 5px; }
        .subtitle { color: #777; margin-bottom: 30px; font-size: 14px; }
        .amount { font-size: 36px; font-weight: bold; color: #0052cc; margin-bottom: 30px; }
        .btn { display: block; width: 100%; padding: 15px; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; transition: 0.3s; margin-bottom: 15px; text-decoration: none; }
        .btn-success { background: #00ca72; color: white; }
        .btn-success:hover { background: #00a85f; }
        .btn-danger { background: #ff4d4f; color: white; }
        .btn-danger:hover { background: #d9363e; }
        .footer { margin-top: 20px; font-size: 12px; color: #aaa; }
    </style>
</head>
<body>

    <div class="checkout-box">
        <h2>Paymob Secure Checkout</h2>
        <div class="subtitle">Test Mode Environment</div>

        <div class="amount"><%=  %> EGP</div>
        <p style="color: #555; margin-bottom: 30px;">For the purchase of <strong><%=  %> Pt</strong> Core Energy.</p>

        <a href="//" class="btn btn-success">Simulate Successful Payment</a>
        <a href="//" class="btn btn-danger">Simulate Declined Payment</a>
        
        <div class="footer">
            Powered by Paymob
        </div>
    </div>

</body>
</html>
